<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <URI>\NetworkDriveBackup</URI>
    <Description>マップドライブ依存。VISION の explain 例 (Z:\scripts\backup.ps1) に対応。</Description>
  </RegistrationInfo>
  <Principals>
    <Principal id="Author">
      <UserId>S-1-5-18</UserId>
      <RunLevel>HighestAvailable</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <Enabled>true</Enabled>
    <MultipleInstancesPolicy>Parallel</MultipleInstancesPolicy>
    <ExecutionTimeLimit>PT30S</ExecutionTimeLimit>
  </Settings>
  <Triggers>
    <TimeTrigger>
      <StartBoundary>2026-01-01T03:00:00+09:00</StartBoundary>
      <Enabled>true</Enabled>
    </TimeTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-File Z:\scripts\backup.ps1</Arguments>
      <WorkingDirectory>%USERPROFILE%\work</WorkingDirectory>
    </Exec>
  </Actions>
</Task>
