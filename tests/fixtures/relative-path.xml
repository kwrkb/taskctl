<?xml version="1.0" encoding="UTF-16"?>
<Task version="1.2" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <URI>\RelativePathTask</URI>
    <Description>作業ディレクトリ未設定 + 相対パス。ヒューリスティックなので Warning/調査 止まり。</Description>
  </RegistrationInfo>
  <Principals>
    <Principal id="Author">
      <UserId>S-1-5-21-1111111111-2222222222-3333333333-1001</UserId>
      <LogonType>InteractiveToken</LogonType>
    </Principal>
  </Principals>
  <Settings>
    <Enabled>true</Enabled>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <ExecutionTimeLimit>PT72H</ExecutionTimeLimit>
  </Settings>
  <Triggers>
    <TimeTrigger>
      <StartBoundary>2026-01-01T09:00:00+09:00</StartBoundary>
      <Enabled>true</Enabled>
    </TimeTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>scripts\run.bat</Command>
      <Arguments>--daily</Arguments>
    </Exec>
  </Actions>
</Task>
